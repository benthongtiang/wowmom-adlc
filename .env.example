# Database
DATABASE_URL=postgres://user:password@localhost:5432/wow_mom_app

# SMTP (notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Auth
JWT_SECRET=replace-me-with-secure-secret
SESSION_SECRET=replace-me-with-secure-secret

# Application limits
MAX_CONCURRENT_APPS_PER_MOTHER=3
GROUP_MIN_CAPACITY=2
GROUP_MAX_CAPACITY=15
REAPP_COOLDOWN_DAYS=30
INTERVIEW_SLA_DAYS=7

# Application metadata
APP_URL=http://localhost:3000
APP_NAME=WoW Mom App
